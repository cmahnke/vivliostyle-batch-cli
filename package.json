{
  "name": "@projektemacher/vivliostyle-batch-cli",
  "version": "0.1.3",
  "type": "module",
  "description": "A vivliostyle-cli with more options for batch processing",
  "bin": {
    "vivliostyle-batch-cli": "dist/vivliostyle-batch-cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "npx vitest",
    "build": "npx rimraf dist/* && npx rollup -c",
    "start": "node dist/vivliostyle-cli.js",
    "format": "npx prettier . --check",
    "clean": "npx rimraf dist/*",
    "lint": "npx tsc && eslint . -c eslint.config.mjs --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@vivliostyle/cli": "^10.6.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "jsdom": "^29.1.1",
    "mime-types": "^3.0.2",
    "serve-static": "^2.2.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.3",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.9.0",
    "@types/serve-static": "^2.2.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  },
  "license": "MIT",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/vivliostyle-cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pdf",
    "css",
    "vivliostyle",
    "print"
  ],
  "bugs": {
    "url": "https://github.com/cmahnke/vivliostyle-batch-cli/issues"
  },
  "repository": {
    "url": "git+https://github.com/cmahnke/vivliostyle-batch-cli.git"
  },
  "homepage": "https://github.com/cmahnke/vivliostyle-batch-cli#readme"
}
